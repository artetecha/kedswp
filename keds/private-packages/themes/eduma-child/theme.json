{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "780px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"palette": [
				{ "slug": "base", "name": "White", "color": "#ffffff" },
				{ "slug": "surface", "name": "Surface", "color": "#f5f6fa" },
				{ "slug": "surface-2", "name": "Surface (deep)", "color": "#eceef5" },
				{ "slug": "indigo-050", "name": "Indigo tint", "color": "#eef0f8" },
				{ "slug": "primary", "name": "Indigo", "color": "#24256c" },
				{ "slug": "primary-700", "name": "Indigo (dark)", "color": "#1a1b52" },
				{ "slug": "accent", "name": "Gold", "color": "#ffb606" },
				{ "slug": "accent-600", "name": "Gold (dark)", "color": "#d99a00" },
				{ "slug": "ink", "name": "Ink", "color": "#2b2b33" },
				{ "slug": "body", "name": "Body text", "color": "#5c5c66" },
				{ "slug": "muted", "name": "Muted", "color": "#8a8a94" },
				{ "slug": "border", "name": "Border", "color": "#e2e4ed" }
			],
			"gradients": [
				{
					"slug": "hero",
					"name": "Hero wash",
					"gradient": "linear-gradient(180deg, #eef0f8 0%, #ffffff 100%)"
				},
				{
					"slug": "indigo",
					"name": "Indigo depth",
					"gradient": "linear-gradient(135deg, #24256c 0%, #1a1b52 100%)"
				}
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"customFontSize": true,
			"lineHeight": true,
			"fontFamilies": [
				{
					"slug": "body",
					"name": "Work Sans",
					"fontFamily": "\"Work Sans\", \"WorkSans Fallback\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
				},
				{
					"slug": "display",
					"name": "Libre Baskerville",
					"fontFamily": "\"Libre Baskerville\", \"LibreBaskerville Fallback\", Georgia, \"Times New Roman\", serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem" },
				{ "slug": "medium", "name": "Medium", "size": "1rem" },
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem",
					"fluid": { "min": "1.125rem", "max": "1.25rem" }
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.75rem",
					"fluid": { "min": "1.5rem", "max": "1.75rem" }
				},
				{
					"slug": "xx-large",
					"name": "Heading",
					"size": "2.5rem",
					"fluid": { "min": "2rem", "max": "2.5rem" }
				},
				{
					"slug": "huge",
					"name": "Display",
					"size": "3.5rem",
					"fluid": { "min": "2.5rem", "max": "3.5rem" }
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "20", "name": "1 · XS", "size": "0.5rem" },
				{ "slug": "30", "name": "2 · S", "size": "0.75rem" },
				{ "slug": "40", "name": "3 · M", "size": "1rem" },
				{ "slug": "50", "name": "4 · L", "size": "1.5rem" },
				{
					"slug": "60",
					"name": "5 · XL",
					"size": "clamp(2rem, 4vw, 2.5rem)"
				},
				{
					"slug": "70",
					"name": "6 · 2XL",
					"size": "clamp(3rem, 6vw, 4rem)"
				},
				{
					"slug": "80",
					"name": "7 · 3XL",
					"size": "clamp(4rem, 8vw, 6rem)"
				}
			]
		},
		"border": {
			"radius": true,
			"color": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"text": "var:preset|color|body",
			"background": "var:preset|color|base"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|body",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.7"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|50",
			"padding": {
				"left": "var:preset|spacing|50",
				"right": "var:preset|spacing|50"
			}
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": { "text": "var:preset|color|ink" }
			},
			"h1": { "typography": { "fontSize": "var:preset|font-size|huge" } },
			"h2": { "typography": { "fontSize": "var:preset|font-size|xx-large" } },
			"h3": { "typography": { "fontSize": "var:preset|font-size|x-large" } },
			"h4": { "typography": { "fontSize": "var:preset|font-size|large" } },
			"link": {
				"color": { "text": "var:preset|color|primary" },
				":hover": { "color": { "text": "var:preset|color|accent-600" } }
			},
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|body",
					"fontWeight": "600"
				},
				"border": { "radius": "6px" },
				"spacing": {
					"padding": {
						"top": "0.85rem",
						"bottom": "0.85rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				":hover": {
					"color": { "background": "var:preset|color|primary-700" }
				},
				":focus": {
					"color": { "background": "var:preset|color|primary-700" }
				}
			}
		},
		"blocks": {
			"core/heading": {
				"color": { "text": "var:preset|color|ink" }
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|display",
					"fontWeight": "700"
				}
			}
		}
	}
}
